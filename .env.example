# Supabase — copy to .env and fill in from your project's API settings
# (Supabase dashboard → Project Settings → API)

# Exposed to the app bundle (safe to ship: anon key is public + protected by RLS)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — used ONLY by supabase/seed.ts to bulk-insert seed data.
# NEVER prefix this with EXPO_PUBLIC_ and never ship it in the app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
